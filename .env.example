# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_NAME="Multi-Branch Accounting SaaS"
APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://saas_user:saas_password@localhost:5432/accounting_saas?schema=public

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long_value
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long_value
# Access token lifetime in seconds (default 15 minutes)
JWT_ACCESS_TTL=900
# Refresh token lifetime in seconds (default 7 days)
JWT_REFRESH_TTL=604800
JWT_ISSUER=accounting-saas
JWT_AUDIENCE=accounting-saas-clients

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
BCRYPT_SALT_ROUNDS=12
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# Seed defaults (used by prisma/seed.ts)
# ---------------------------------------------------------------------------
SEED_SUPER_ADMIN_EMAIL=admin@accounting-saas.uz
SEED_SUPER_ADMIN_PASSWORD=Admin12345!
SEED_BOSS_EMAIL=boss.chilonzor@accounting-saas.uz
SEED_BOSS_PASSWORD=Boss12345!
SEED_EMPLOYEE_EMAIL=employee.chilonzor@accounting-saas.uz
SEED_EMPLOYEE_PASSWORD=Employee12345!
